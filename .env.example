# ─── BASE DE DATOS (Neon) ────────────────────────────────────────────────────
# Pooled connection (para runtime / queries)
DATABASE_URL="postgresql://user:pass@ep-xxx.us-east-2.aws.neon.tech/neondb?sslmode=require&pgbouncer=true"
# Direct connection (para migraciones Prisma)
DIRECT_URL="postgresql://user:pass@ep-xxx.us-east-2.aws.neon.tech/neondb?sslmode=require"

# ─── NEXTAUTH ─────────────────────────────────────────────────────────────────
# Generar con: openssl rand -base64 32
AUTH_SECRET="genera_un_secreto_muy_largo_y_aleatorio_aqui"
NEXTAUTH_URL="http://localhost:3000"

# ─── MERCADO PAGO ─────────────────────────────────────────────────────────────
# Obtener en: https://www.mercadopago.com.ar/developers/panel
MP_ACCESS_TOKEN="APP_USR-xxxx-ACCESS-TOKEN"
NEXT_PUBLIC_MP_PUBLIC_KEY="APP_USR-xxxx-PUBLIC-KEY"
MP_WEBHOOK_SECRET="tu_clave_secreta_webhook_mp"

# ─── VERCEL BLOB ──────────────────────────────────────────────────────────────
BLOB_READ_WRITE_TOKEN="vercel_blob_rw_xxxxxxxxxxxx"

# ─── TOKENS DE DESCARGA ───────────────────────────────────────────────────────
# Mínimo 32 caracteres aleatorios
DOWNLOAD_TOKEN_SECRET="cambia_esto_por_32_caracteres_random"

# ─── RATE LIMITING (Upstash - opcional) ──────────────────────────────────────
UPSTASH_REDIS_REST_URL="https://xxx.upstash.io"
UPSTASH_REDIS_REST_TOKEN="xxxxxxxxxxxx"

# ─── EMAIL (Resend - opcional) ────────────────────────────────────────────────
RESEND_API_KEY="re_xxxxxxxxxxxx"
EMAIL_FROM="Andrew Myer <noreply@andrewmyer.com>"

# ─── APP ──────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL="http://localhost:3000"
